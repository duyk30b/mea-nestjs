{
    "name": "mea-nestjs",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "start": "nest start",
        "dev": "nest start --debug --watch",
        "debug": "nest start --debug 0.0.0.0:29229 --watch",
        "build": "nest build",
        "lint": "eslint \"apps/**/*.ts\" \"libs/**/*.ts\" --fix",
        "prettier": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\" \"!data/**\" \"!assets/**\"",
        "test": "jest",
        "test:command": "nest build command-line & node ./dist/apps/command-line/main.js seed:data",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./apps/api/test/jest-e2e.json",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli -d apps/_libs/database/common/data-source.ts",
        "migration:generate": "cross-var npm run typeorm -- migration:generate -p apps/_libs/database/migrations/$npm_config_name",
        "migration:create": "cross-var ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli migration:create apps/_libs/database/migrations/$npm_config_name",
        "migration:run": "npm run typeorm -- migration:run",
        "migration:revert": "npm run typeorm -- migration:revert",
        "seed:data": "npm run build seed-data && node dist/apps/seed-data/main.js start:seed",
        "stop:local": "taskkill /f /im node.exe"
    },
    "dependencies": {
        "@faker-js/faker": "^7.6.0",
        "@nestjs-modules/mailer": "^1.8.1",
        "@nestjs/axios": "^1.0.1",
        "@nestjs/bull": "^0.6.2",
        "@nestjs/cli": "^10.1.18",
        "@nestjs/common": "^9.0.0",
        "@nestjs/config": "^2.2.0",
        "@nestjs/core": "^9.0.0",
        "@nestjs/jwt": "^9.0.0",
        "@nestjs/mapped-types": "*",
        "@nestjs/microservices": "^9.2.1",
        "@nestjs/platform-express": "^9.0.0",
        "@nestjs/platform-socket.io": "^9.2.1",
        "@nestjs/schedule": "^3.0.1",
        "@nestjs/swagger": "^6.1.3",
        "@nestjs/terminus": "^9.1.4",
        "@nestjs/throttler": "^3.1.0",
        "@nestjs/typeorm": "^9.0.1",
        "@nestjs/websockets": "^9.2.1",
        "@types/express": "^4.17.21",
        "axios": "^1.4.0",
        "bcrypt": "^5.1.0",
        "bull": "^4.10.2",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.13.2",
        "cross-var": "^1.1.0",
        "helmet": "^6.0.0",
        "kafkajs": "^2.2.3",
        "mysql2": "^2.3.3",
        "nest-commander": "^3.6.1",
        "nestjs-i18n": "^10.3.1",
        "nodemailer": "^6.9.3",
        "pg": "^8.11.3",
        "prettier": "^3.1.0",
        "reflect-metadata": "^0.1.13",
        "request-ip": "^3.3.0",
        "rimraf": "^3.0.2",
        "rxjs": "^7.2.0",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.1.0",
        "typeorm": "^0.3.10",
        "typescript": "^4.9.3"
    },
    "devDependencies": {
        "@nestjs/schematics": "^9.0.0",
        "@nestjs/testing": "^9.0.0",
        "@types/bcrypt": "^5.0.0",
        "@types/jest": "28.1.8",
        "@types/node": "^16.0.0",
        "@types/request-ip": "^0.0.37",
        "@types/supertest": "^2.0.11",
        "@typescript-eslint/eslint-plugin": "^5.0.0",
        "@typescript-eslint/parser": "^5.0.0",
        "eslint": "^8.0.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.0.1",
        "jest": "28.1.3",
        "source-map-support": "^0.5.20",
        "supertest": "^6.1.3",
        "ts-jest": "28.0.8",
        "webpack": "^5.75.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/apps/",
            "<rootDir>/libs/"
        ],
        "moduleNameMapper": {
        }
    }
}
